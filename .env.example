# ==============================================================================
# SearchSwarm harness configuration example
# Copy this file to `.env` and fill in local paths / API keys.
# Do not commit `.env`.
# ==============================================================================

# Main model mode: `local` uses vLLM servers on ports 6001-6008; `api` uses an
# OpenAI-compatible endpoint.
MODEL_MODE=api
MODEL_PATH=SearchSwarm-30B-A3B
TEMPLATE=qwen3

# API mode only. `run_multi_react.py` appends `/v1`.
API_BASE_URL=http://localhost:8000
API_KEY=EMPTY

# Dataset and outputs.
DATASET=eval_data/example/standardized_data.jsonl
OUTPUT_PATH=./results
EXPERIMENT_NAME=example

# Sampling and parallelism.
ROLLOUT_COUNT=1
MAX_WORKERS=64
MAX_WORKERS_POOL_CAP=1024
TEMPERATURE=0.85
TOP_P=0.95
PRESENCE_PENALTY=1.1
MAX_LLM_CALL_PER_RUN=800
MAX_CONTEXT_TOKENS=131072
MAX_GENERATION_TOKENS=8192
TOKEN_COUNTER=api
RUN_TIMEOUT_MINUTES=2000

# Tools.
SEARCH_MODE=multi
TOOL_TYPE=four
SEARCH_NUM_RESULTS=10
SERPER_API_KEY=YOUR_SERPER_API_KEY
JINA_API_KEY=YOUR_JINA_API_KEY

# Subagent delegation.
ENABLE_SUB_AGENT=1
SUB_AGENT_MODE=api
SUB_AGENT_MODEL=SearchSwarm-30B-A3B
SUB_AGENT_MAX_CONTEXT_TOKENS=65536
SUB_AGENT_MAX_GENERATION_TOKENS=8192
SUB_AGENT_MAX_LLM_CALLS=50
SUB_AGENT_TIMEOUT_MINUTES=600
SUB_AGENT_TEMPERATURE=0.85
SUB_AGENT_TOP_P=0.95
SUB_AGENT_PRESENCE_PENALTY=1.1

# Local vLLM serving. Used by `deploy_model.sh` when MODEL_MODE=local or
# SUB_AGENT_MODE=local.
VLLM_MODEL=SearchSwarm-30B-A3B
VLLM_EXTRA_ARGS="--max-model-len 131072"

# Judge model.
JUDGE_MODEL_MODE=api
JUDGE_MODEL_NAME=judge-model-name

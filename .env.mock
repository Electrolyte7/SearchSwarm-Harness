# Smoke-test configuration for running the harness end to end against the
# bundled example dataset and a local mock OpenAI-compatible server.

MODEL_MODE=api
MODEL_PATH=mock-searchswarm
TEMPLATE=qwen3

API_BASE_URL=http://127.0.0.1:18080
API_KEY=EMPTY
SUMMARY_MODEL_NAME=mock-searchswarm

DATASET=eval_data/example/standardized_data.jsonl
OUTPUT_PATH=./results
EXPERIMENT_NAME=mock-smoke

ROLLOUT_COUNT=1
MAX_WORKERS=2
MAX_WORKERS_POOL_CAP=8
TEMPERATURE=0
TOP_P=1
PRESENCE_PENALTY=0
MAX_LLM_CALL_PER_RUN=4
MAX_CONTEXT_TOKENS=32768
MAX_GENERATION_TOKENS=1024
TOKEN_COUNTER=api
RUN_TIMEOUT_MINUTES=10

SEARCH_MODE=multi
TOOL_TYPE=two
SEARCH_NUM_RESULTS=5
SERPER_API_KEY=
JINA_API_KEY=

ENABLE_SUB_AGENT=0
SUB_AGENT_MODE=api
SUB_AGENT_MODEL=mock-searchswarm
SUB_AGENT_MAX_CONTEXT_TOKENS=16384
SUB_AGENT_MAX_GENERATION_TOKENS=1024
SUB_AGENT_MAX_LLM_CALLS=4
SUB_AGENT_TIMEOUT_MINUTES=10
SUB_AGENT_TEMPERATURE=0
SUB_AGENT_TOP_P=1
SUB_AGENT_PRESENCE_PENALTY=0

VLLM_MODEL=mock-searchswarm
VLLM_EXTRA_ARGS=

JUDGE_MODEL_MODE=api
JUDGE_MODEL_NAME=mock-searchswarm
